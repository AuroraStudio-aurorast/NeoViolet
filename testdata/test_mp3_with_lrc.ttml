    <div begin="0.000" end="0:35.000" xml:lang="en">
      <p begin="0.000" end="1.720" itunes:key="L1" ttm:agent="v1">
        <span begin="0.000" end="0.283">This</span>
        <span begin="0.283" end="0.460">is</span>
        <span begin="0.460" end="0.614">the</span>
