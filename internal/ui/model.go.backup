package ui

import (
	"fmt"
	"path/filepath"
	"time"

	"charm.land/bubbles/v2/help"
	"charm.land/bubbles/v2/key"
	"charm.land/bubbles/v2/progress"
	"charm.land/bubbles/v2/textinput"
	tea "charm.land/bubbletea/v2"
	"charm.land/lipgloss/v2"

	"neoviolet/internal/audio"
	"neoviolet/internal/logger"
)

var tabNames = []string{"Home", "Playlists", "Effects", "Settings"}

type KeyMap struct {
	TabNext     key.Binding
	TabPrev     key.Binding
	Play        key.Binding
	Pause       key.Binding
	SeekLeft    key.Binding
	SeekRight   key.Binding
	VolUp       key.Binding
	VolDown     key.Binding
	SeekStart   key.Binding
	SeekEnd     key.Binding
	Command     key.Binding
	Quit        key.Binding
	QuitAll     key.Binding
	ModeNormal  key.Binding
	EnterTab    key.Binding
	EnterFooter key.Binding
}

var keys = KeyMap{
	TabNext: key.NewBinding(
		key.WithKeys("]", "n"),
		key.WithHelp("]", "next tab"),
	),
	TabPrev: key.NewBinding(
		key.WithKeys("[", "p"),
		key.WithHelp("[", "prev tab"),
	),
	Play: key.NewBinding(
		key.WithKeys("space"),
		key.WithHelp("space", "play"),
	),
	Pause: key.NewBinding(
		key.WithKeys("space"),
		key.WithHelp("space", "pause"),
	),
	SeekLeft: key.NewBinding(
		key.WithKeys("h", "left"),
		key.WithHelp("h/←", "seek -5s"),
	),
	SeekRight: key.NewBinding(
		key.WithKeys("l", "right"),
		key.WithHelp("l/→", "seek +5s"),
	),
	VolUp: key.NewBinding(
		key.WithKeys("+", "="),
		key.WithHelp("+/=", "volume up"),
	),
	VolDown: key.NewBinding(
		key.WithKeys("-"),
		key.WithHelp("-", "volume down"),
	),
	SeekStart: key.NewBinding(
		key.WithKeys("g", "0"),
		key.WithHelp("g/0", "seek start"),
	),
	SeekEnd: key.NewBinding(
		key.WithKeys("G"),
		key.WithHelp("G", "seek end"),
	),
	Command: key.NewBinding(
		key.WithKeys(":"),
		key.WithHelp(":", "command mode"),
	),
	Quit: key.NewBinding(
		key.WithKeys("q"),
		key.WithHelp("q", "quit"),
	),
	QuitAll: key.NewBinding(
		key.WithKeys("ctrl+c"),
		key.WithHelp("ctrl+c", "force quit"),
	),
	ModeNormal: key.NewBinding(
		key.WithKeys("escape", "esc"),
		key.WithHelp("esc", "normal mode"),
	),
	EnterTab: key.NewBinding(
		key.WithKeys("tab"),
		key.WithHelp("tab", "focus tab"),
	),
	EnterFooter: key.NewBinding(
		key.WithKeys("enter"),
		key.WithHelp("enter", "focus footer"),
	),
}

func (k KeyMap) ShortHelp() []key.Binding {
	return []key.Binding{
		k.Play,
		k.SeekLeft,
		k.SeekRight,
		k.Command,
		k.Quit,
	}
}

func (k KeyMap) FullHelp() [][]key.Binding {
	return [][]key.Binding{
		{k.Play, k.SeekLeft, k.SeekRight},
		{k.TabNext, k.TabPrev, k.SeekStart, k.SeekEnd},
		{k.VolUp, k.VolDown},
		{k.Command},
		{k.Quit, k.QuitAll},
	}
}

type Mode int

const (
	ModeNormal Mode = iota
	ModeCommand
)

type Focus int

const (
	FocusTabBar Focus = iota
	FocusContent
	FocusFooter
)

type Model struct {
	ActiveTab int
	Tabs      []string
	Mode      Mode

	Player *audio.Player

	CurrentSong string
	Artist      string
	Progress    float64
	Volume      float64
	Duration    time.Duration
	Elapsed     time.Duration

	Focus        Focus
	ProgressBar  progress.Model
	VolumeBar    progress.Model
	Help         help.Model
	CommandInput textinput.Model
	Width        int
	Height       int
	tabWidth     int

	QuitConfirm  bool
	ErrorMessage string
	ErrorTimer   int
}

func (m *Model) cleanup() {
	if m.Player != nil {
		m.Player.Close()
		m.Player = nil
	}

	m.CurrentSong = ""
	m.Artist = ""
	m.Progress = 0
	m.Duration = 0
	m.Elapsed = 0
}

func NewModel(filePath string) *Model {
	pb := progress.New(
		progress.WithColors(
			lipgloss.Color("#DA70D6"),
			lipgloss.Color("#8A2BE2"),
		),
		progress.WithFillCharacters('█', '░'),
		progress.WithScaled(true),
		progress.WithoutPercentage(),
	)
	pb.SetWidth(60)

	vb := progress.New(
		progress.WithColors(
			lipgloss.Color("#00FF00"),
			lipgloss.Color("#FF0000"),
		),
		progress.WithFillCharacters('▰', '▱'),
		progress.WithScaled(false),
		progress.WithoutPercentage(),
	)
	vb.SetWidth(10)

	h := help.New()
	h.ShowAll = false

	ti := textinput.New()
	ti.Placeholder = ""
	ti.EchoMode = textinput.EchoNormal
	ti.CharLimit = 100

	m := &Model{
		ActiveTab:    0,
		Tabs:         tabNames,
		CurrentSong:  "No track loaded",
		Artist:       "Unknown Artist",
		Progress:     0,
		Volume:       1.0,
		Duration:     0,
		Elapsed:      0,
		Focus:        FocusTabBar,
		ProgressBar:  pb,
		VolumeBar:    vb,
		Help:         h,
		CommandInput: ti,
		Width:        80,
		Height:       24,
		tabWidth:     14,
	}

	if filePath != "" {
		m.Player = audio.NewPlayer()
		if err := m.Player.Open(filePath); err != nil {
			m.ErrorMessage = fmt.Sprintf("Failed to open audio file: %v", err)
			m.ErrorTimer = 180
		} else {
			m.Player.SetVolume(m.Volume)
			m.Duration = m.Player.Duration()
			m.ProgressBar.SetPercent(0)

			if m.Player.Title() != "" {
				m.CurrentSong = m.Player.Title()
			} else {
				m.CurrentSong = filepath.Base(filePath)
			}

			if m.Player.Artist() != "" {
				m.Artist = m.Player.Artist()
			} else {
				m.Artist = "Unknown Artist"
			}
		}
	}

	return m
}

func (m *Model) handleTick() (tea.Model, tea.Cmd) {
	if m.Player != nil && m.Player.IsPlaying() {
		m.Elapsed = m.Player.Position()
		if m.Duration > 0 {
			m.Progress = float64(m.Elapsed) / float64(m.Duration)
			if m.Progress > 1.0 {
				m.Progress = 1.0
			}
			if m.Progress < 0 {
				m.Progress = 0
			}
			m.ProgressBar.SetPercent(m.Progress)
		}
		if m.Progress >= 1.0 {
			m.Player.Pause()
			if err := m.Player.Seek(0); err != nil {
				logger.Error("Failed to seek to start after completion", "err", err)
			}
			m.Elapsed = 0
			m.Progress = 0
			m.ProgressBar.SetPercent(0)
		}
	}
	if m.ErrorTimer > 0 {
		m.ErrorTimer--
		if m.ErrorTimer == 0 {
			m.ErrorMessage = ""
		}
	}
	return m, tea.Tick(time.Second/30, func(t time.Time) tea.Msg {
		return struct{}{}
	})
}

func (m *Model) handleResize(msg tea.WindowSizeMsg) (tea.Model, tea.Cmd) {
	m.Width = msg.Width
	m.Height = msg.Height
	m.tabWidth = msg.Width / len(m.Tabs)
	m.ProgressBar.SetWidth(msg.Width - 20)
	m.Help.SetWidth(msg.Width)
	return m, nil
}

func (m *Model) Init() tea.Cmd {
	if m.Player != nil {
		m.Duration = m.Player.Duration()
		if err := m.Player.Play(); err != nil {
			logger.Error("Failed to start playback", "err", err)
			m.ErrorMessage = fmt.Sprintf("Playback failed: %v", err)
			m.ErrorTimer = 180
		} else {
			logger.Info("Player initialized", "duration", m.Duration)
		}
	}
	m.Mode = ModeNormal
	m.QuitConfirm = false
	m.CommandInput.Blur()
	logger.Info("TUI initialized")
	return tea.Batch(
		tea.Tick(time.Second/30, func(time.Time) tea.Msg {
			return struct{}{}
		}),
		textinput.Blink,
	)
}

func (m *Model) Update(msg tea.Msg) (tea.Model, tea.Cmd) {
	switch msg := msg.(type) {
	case struct{}:
		return m.handleTick()

	case tea.WindowSizeMsg:
		return m.handleResize(msg)

	case tea.KeyPressMsg:
		if m.Mode == ModeCommand {
			switch msg.String() {
			case "enter":
				return m.executeCommand()
			case "escape", "esc":
				m.Mode = ModeNormal
				m.CommandInput.Reset()
				m.CommandInput.Blur()
				return m, nil
			case "ctrl+c":
				m.cleanup()
				return m, tea.Quit
			default:
				var cmd tea.Cmd
				m.CommandInput, cmd = m.CommandInput.Update(msg)
				return m, cmd
			}
		}
		return m.handleKeyPress(msg)

	case progress.FrameMsg:
		updatedPb, cmd := m.ProgressBar.Update(msg)
		m.ProgressBar = updatedPb
		return m, cmd

	case tea.MouseClickMsg:
		mouse := msg.Mouse()
		if mouse.Button == tea.MouseLeft {
			return m.handleMouseClick(int(mouse.X), int(mouse.Y))
		}

	case tea.MouseWheelMsg:
		mouse := msg.Mouse()
		switch mouse.Button {
		case tea.MouseWheelUp:
			m.seekRelative(-1 * time.Second)
		case tea.MouseWheelDown:
			m.seekRelative(1 * time.Second)
		}
		return m, nil
	}

	return m, nil
}

func (m *Model) handleKeyPress(msg tea.KeyPressMsg) (tea.Model, tea.Cmd) {
	switch msg.String() {
	case "q":
		if m.QuitConfirm {
			m.cleanup()
			return m, tea.Quit
		}
		m.QuitConfirm = true
	case "ctrl+c":
		m.cleanup()
		return m, tea.Quit

	case ":":
		m.Mode = ModeCommand
		m.CommandInput.Reset()
		m.CommandInput.Focus()
		m.QuitConfirm = false
		return m, textinput.Blink

	case "tab":
		m.Focus = FocusContent
	case "enter":
		m.Focus = FocusFooter

	case "[", "p":
		if m.ActiveTab > 0 {
			m.ActiveTab--
		}
	case "]", "n":
		if m.ActiveTab < len(m.Tabs)-1 {
			m.ActiveTab++
		}

	case "h", "left":
		m.seekRelative(-5 * time.Second)
	case "l", "right":
		m.seekRelative(5 * time.Second)

	case "space":
		m.togglePlayback()

	case "+", "=":
		m.adjustVolume(0.1)
	case "-":
		m.adjustVolume(-0.1)

	case "g":
		m.Seek(0)
	case "G":
		if m.Duration > 0 {
			m.Seek(m.Duration)
		}
	case "0":
		m.Seek(0)
	}

	return m, nil
}

func (m *Model) executeCommand() (tea.Model, tea.Cmd) {
	cmd := m.CommandInput.Value()
	m.Mode = ModeNormal
	m.CommandInput.Reset()
	m.CommandInput.Blur()

	logger.Info("Command executed", "cmd", cmd)
	switch cmd {
	case "q", "quit", "exit":
		m.cleanup()
		logger.Info("Quit command")
		return m, tea.Quit
	case "wq", "quit!":
		m.cleanup()
		logger.Info("Write and quit command")
		return m, tea.Quit
	default:
		m.ErrorMessage = "Not an editor command: " + cmd
		m.ErrorTimer = 90
		logger.Warn("Unknown command", "cmd", cmd)
	}
	return m, nil
}

func (m *Model) togglePlayback() {
	if m.Player == nil {
		return
	}
	if m.Player.IsPlaying() {
		m.Player.Pause()
	} else {
		if err := m.Player.Play(); err != nil {
			logger.Error("Playback failed in toggle", "err", err)
			m.ErrorMessage = fmt.Sprintf("Playback failed: %v", err)
			m.ErrorTimer = 90
		}
	}
}

func (m *Model) Seek(position time.Duration) {
	if m.Player == nil || m.Duration == 0 {
		return
	}
	if position < 0 {
		position = 0
	}
	if position > m.Duration {
		position = m.Duration
	}
	if err := m.Player.Seek(position); err != nil {
		logger.Error("Seek failed", "err", err, "position", position)
		m.ErrorMessage = fmt.Sprintf("Seek failed: %v", err)
		m.ErrorTimer = 90
	} else {
		m.Elapsed = position
		m.Progress = float64(m.Elapsed) / float64(m.Duration)
	}
}

func (m *Model) seekRelative(delta time.Duration) {
	if m.Player == nil || m.Duration == 0 {
		return
	}
	newPos := m.Elapsed + delta
	if newPos < 0 {
		newPos = 0
	}
	if newPos > m.Duration {
		newPos = m.Duration
	}
	m.Seek(newPos)
}

func (m *Model) adjustVolume(delta float64) {
	m.Volume += delta
	if m.Volume > 1.0 {
		m.Volume = 1.0
	}
	if m.Volume < 0 {
		m.Volume = 0
	}

	if m.Player != nil {
		m.Player.SetVolume(m.Volume)
	}

	m.VolumeBar.SetPercent(m.Volume)
}

func (m *Model) handleMouseClick(x, y int) (tea.Model, tea.Cmd) {
	if m.Mode != ModeNormal {
		return m, nil
	}

	tabBarLine := 0
	helpLine := m.Height - 3
	songLine := m.Height - 6

	if y == tabBarLine {
		if x >= 0 && x < len(m.Tabs)*m.tabWidth {
			m.ActiveTab = (x / m.tabWidth) % len(m.Tabs)
			return m, nil
		}
		return m, nil
	}

	if y == songLine {
		m.togglePlayback()
		return m, nil
	}

	if y == helpLine {
		m.Mode = ModeCommand
		m.CommandInput.Reset()
		m.CommandInput.Focus()
		return m, textinput.Blink
	}

	return m, nil
}

func (m *Model) View() tea.View {
	return renderMainView(m)
}
